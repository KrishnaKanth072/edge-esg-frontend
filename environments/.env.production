# EDGE ESG Frontend - Production Environment
# This file is used for production deployment

# Backend API Configuration (Update with your production backend URL)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws

# Keycloak Authentication
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.yourdomain.com
NEXT_PUBLIC_KEYCLOAK_REALM=edgeesg
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=edge-esg-frontend

# Environment
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_LOG_LEVEL=error

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_KEYCLOAK=true

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Performance
NEXT_PUBLIC_ENABLE_COMPRESSION=true
NEXT_PUBLIC_ENABLE_CACHING=true

# Security
NEXT_PUBLIC_ENABLE_CSP=true
NEXT_PUBLIC_ENABLE_HSTS=true
