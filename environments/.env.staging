# EDGE ESG Frontend - Staging Environment
# This file is used for staging/testing deployment

# Backend API Configuration (Update with your staging backend URL)
NEXT_PUBLIC_API_URL=https://staging-api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://staging-api.yourdomain.com/ws

# Keycloak Authentication
NEXT_PUBLIC_KEYCLOAK_URL=https://staging-auth.yourdomain.com
NEXT_PUBLIC_KEYCLOAK_REALM=edgeesg
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=edge-esg-frontend

# Environment
NEXT_PUBLIC_ENVIRONMENT=staging
NEXT_PUBLIC_LOG_LEVEL=info

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO_MODE=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_KEYCLOAK=true

# Analytics (Optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
